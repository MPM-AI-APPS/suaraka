# --- Next / App ---
NEXT_PUBLIC_APP_NAME=Suaraka
NEXT_PUBLIC_BASE_PATH=
# Set to "false" to disable the audio/TTS feature entirely (text-only mode)
NEXT_PUBLIC_ENABLE_AUDIO=true
# Set to "true" to skip login entirely and use a built-in local user
NEXT_PUBLIC_DISABLE_LOGIN=false
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Keycloak (OIDC) ---
KEYCLOAK_CLIENT_ID=suaraka-web
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ISSUER=http://localhost:8080/realms/suaraka

# --- Database (Postgres) ---
DATABASE_URL=postgresql://suaraka:suaraka@localhost:5432/suaraka

# --- Storage ---
# Local filesystem path (relative to project root) used for uploaded PDFs
# and generated audio. In production, swap for S3/GCS.
STORAGE_DIR=./.storage

# --- TTS Server (Edge TTS) ---
# Base URL for the TTS server (chatterbox-server/).
# Uses Microsoft Edge TTS (online, no GPU required).
CHATTERBOX_BASE_URL=http://localhost:8100

# --- LLM for Q&A, summary, notes ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
