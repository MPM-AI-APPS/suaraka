# --- Next / App ---
NEXT_PUBLIC_APP_NAME=Suaraka
NEXT_PUBLIC_BASE_PATH=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Keycloak (OIDC) ---
KEYCLOAK_CLIENT_ID=suaraka-web
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ISSUER=http://localhost:8080/realms/suaraka

# --- Database (Postgres) ---
DATABASE_URL=postgresql://suaraka:suaraka@localhost:5432/suaraka

# --- Storage ---
# Local filesystem path (relative to project root) used for uploaded PDFs
# and generated audio. In production, swap for S3/GCS.
STORAGE_DIR=./.storage

# --- Chatterbox TTS ---
# Base URL for the Chatterbox TTS server (see chatterbox-server/).
# When using docker-compose, the service name resolves automatically.
CHATTERBOX_BASE_URL=http://localhost:8100
CHATTERBOX_API_KEY=

# --- LLM for Q&A, summary, notes ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
